<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Campana en la parte superior izquierda -->
    <ImageView
        android:id="@+id/iv_bell"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icono_campana"
        tools:ignore="MissingConstraints" />
    <!-- desplegable en la parte superior derecha -->

    <!-- Menú desplegable en la parte superior derecha -->

    <!-- Agenda en el centro (RecyclerView) -->

    <!-- Calendario en la parte inferior -->
    <ImageView
        android:id="@+id/icono_desplegable"
        android:layout_width="69dp"
        android:layout_height="61dp"
        android:src="@drawable/icono_menu"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="342dp"
        tools:layout_editor_absoluteY="0dp" />

    <RecyclerView
        android:id="@+id/rv_agenda"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:clipToPadding="false"
        android:padding="10dp"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toTopOf="@id/grid_calendar"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_bell" />

    <androidx.gridlayout.widget.GridLayout
        android:id="@+id/grid_calendar"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:background="#f0f0f0"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rv_agenda">
        <!-- Aquí puedes agregar los elementos del calendario o usar un componente como CalendarView -->


</androidx.constraintlayout.widget.ConstraintLayout>
